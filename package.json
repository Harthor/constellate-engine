{
  "name": "constellate-engine",
  "version": "0.1.0",
  "description": "Discover non-obvious patterns across large idea corpora using AI-powered constellation detection",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch cli/index.ts",
    "cli": "tsx cli/index.ts",
    "demo": "tsx examples/demo.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ cli/ tests/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "clear-cache": "tsx scripts/clear-cache.ts",
    "generate-embeddings": "tsx scripts/generate-embeddings.ts"
  },
  "keywords": [
    "constellation",
    "pattern-detection",
    "idea-analysis",
    "clustering",
    "ai",
    "claude"
  ],
  "author": "Harthor",
  "license": "BUSL-1.1",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "better-sqlite3": "^11.7.0",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
